@page "/accounts"
@attribute [Authorize]
@inject IAccountService AccountService
@using AIIntegratedCRM.Blazor.Models
@using AIIntegratedCRM.Blazor.Services
@using Microsoft.AspNetCore.Authorization

<PageTitle>Accounts - AI CRM</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1 fw-bold">Accounts</h4>
        <p class="text-muted mb-0">Manage your business accounts and organizations</p>
    </div>
    <button class="btn btn-primary" @onclick="() => showCreateModal = true">
        <i class="bi bi-plus-lg me-2"></i>New Account
    </button>
</div>

<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <div class="row g-3 align-items-center">
            <div class="col-md-6">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" class="form-control border-start-0" placeholder="Search accounts by name, industry..."
                           @bind="searchTerm" @bind:event="oninput" @onkeyup="OnSearch" />
                </div>
            </div>
            <div class="col-md-6 text-md-end">
                @if (accounts is not null)
                {
                    <small class="text-muted">
                        <i class="bi bi-building me-1"></i>@accounts.TotalCount accounts total
                    </small>
                }
            </div>
        </div>
    </div>
</div>

@if (isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary"></div>
        <p class="text-muted mt-2">Loading accounts...</p>
    </div>
}
else if (accounts?.Items.Count == 0)
{
    <div class="text-center py-5">
        <i class="bi bi-building display-3 text-muted"></i>
        <h5 class="mt-3 text-muted">No accounts found</h5>
        <p class="text-muted small">@(string.IsNullOrEmpty(searchTerm) ? "Create your first account to track your business relationships." : "Try a different search term.")</p>
        <button class="btn btn-primary mt-2" @onclick="() => showCreateModal = true">
            <i class="bi bi-plus-lg me-2"></i>Add Account
        </button>
    </div>
}
else
{
    <div class="row g-3 mb-3">
        @foreach (var account in accounts!.Items)
        {
            <div class="col-xl-4 col-md-6">
                <div class="card border-0 shadow-sm h-100" style="transition:all 0.2s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 12px rgba(0,0,0,0.1)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
                    <div class="card-body">
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <div class="rounded-2 d-flex align-items-center justify-content-center flex-shrink-0"
                                 style="width:44px;height:44px;background:linear-gradient(135deg,#4f46e522,#7c3aed22);border:1px solid #818cf8;">
                                <i class="bi bi-building text-primary"></i>
                            </div>
                            <div class="flex-grow-1 min-width-0">
                                <h6 class="fw-bold mb-0 text-truncate">@account.Name</h6>
                                @if (!string.IsNullOrEmpty(account.Industry))
                                {
                                    <span class="badge bg-secondary-subtle text-secondary rounded-pill small">@account.Industry</span>
                                }
                            </div>
                        </div>
                        <div class="row g-2 text-sm">
                            @if (!string.IsNullOrEmpty(account.Website))
                            {
                                <div class="col-12">
                                    <small class="text-muted">
                                        <i class="bi bi-globe me-1"></i>
                                        <a href="@(account.Website.StartsWith("http") ? account.Website : "https://" + account.Website)"
                                           target="_blank" class="text-decoration-none">@account.Website</a>
                                    </small>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(account.Phone))
                            {
                                <div class="col-12">
                                    <small class="text-muted"><i class="bi bi-telephone me-1"></i>@account.Phone</small>
                                </div>
                            }
                            @if (!string.IsNullOrEmpty(account.City) || !string.IsNullOrEmpty(account.Country))
                            {
                                <div class="col-12">
                                    <small class="text-muted">
                                        <i class="bi bi-geo-alt me-1"></i>
                                        @(account.City != null ? account.City + ", " : "")@account.Country
                                    </small>
                                </div>
                            }
                        </div>
                        <hr class="my-2" />
                        <div class="row g-2">
                            @if (account.AnnualRevenue.HasValue)
                            {
                                <div class="col-6">
                                    <small class="text-muted d-block">Annual Revenue</small>
                                    <span class="fw-semibold text-success small">@account.AnnualRevenue.Value.ToString("C0")</span>
                                </div>
                            }
                            @if (account.EmployeeCount.HasValue)
                            {
                                <div class="col-6">
                                    <small class="text-muted d-block">Employees</small>
                                    <span class="fw-semibold small">@account.EmployeeCount.Value.ToString("N0")</span>
                                </div>
                            }
                        </div>
                        <div class="mt-2">
                            <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>Added @account.CreatedAt.ToString("MMM dd, yyyy")</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (accounts!.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-2">
            <small class="text-muted">Showing @accounts.Items.Count of @accounts.TotalCount accounts</small>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-outline-secondary" disabled="@(!accounts.HasPreviousPage)" @onclick="PrevPage">
                    <i class="bi bi-chevron-left"></i> Previous
                </button>
                <span class="btn btn-sm disabled">Page @currentPage / @accounts.TotalPages</span>
                <button class="btn btn-sm btn-outline-secondary" disabled="@(!accounts.HasNextPage)" @onclick="NextPage">
                    Next <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    }
}

@if (showCreateModal)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold"><i class="bi bi-building me-2 text-primary"></i>Add New Account</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(createError))
                    {
                        <div class="alert alert-danger d-flex align-items-center">
                            <i class="bi bi-exclamation-triangle me-2"></i>@createError
                        </div>
                    }
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Account Name *</label>
                            <input class="form-control" @bind="newAccount.Name" placeholder="Acme Corporation" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Industry</label>
                            <select class="form-select" @bind="newAccount.Industry">
                                <option value="">Select industry...</option>
                                <option>Technology</option>
                                <option>Finance</option>
                                <option>Healthcare</option>
                                <option>Manufacturing</option>
                                <option>Retail</option>
                                <option>Education</option>
                                <option>Real Estate</option>
                                <option>Consulting</option>
                                <option>Marketing</option>
                                <option>Other</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Phone</label>
                            <input class="form-control" @bind="newAccount.Phone" placeholder="+1 (555) 000-0000" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">Website</label>
                            <input class="form-control" @bind="newAccount.Website" placeholder="https://acmecorp.com" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">City</label>
                            <input class="form-control" @bind="newAccount.City" placeholder="San Francisco" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Country</label>
                            <input class="form-control" @bind="newAccount.Country" placeholder="United States" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Annual Revenue ($)</label>
                            <input class="form-control" type="number" @bind="newAccount.AnnualRevenue" placeholder="1000000" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Employee Count</label>
                            <input class="form-control" type="number" @bind="newAccount.EmployeeCount" placeholder="500" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary px-4" @onclick="CreateAccount" disabled="@isSaving">
                        @if (isSaving) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        <i class="bi bi-building-add me-1"></i>Create Account
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedResult<AccountDto>? accounts;
    private bool isLoading = true;
    private bool showCreateModal = false;
    private bool isSaving = false;
    private string searchTerm = string.Empty;
    private int currentPage = 1;
    private CreateAccountRequest newAccount = new();
    private string? createError;

    protected override async Task OnInitializedAsync() => await LoadAccounts();

    private async Task LoadAccounts()
    {
        isLoading = true;
        accounts = await AccountService.GetAccountsAsync(currentPage, 12, searchTerm);
        isLoading = false;
    }

    private async Task OnSearch() { currentPage = 1; await LoadAccounts(); }
    private async Task PrevPage() { if (currentPage > 1) { currentPage--; await LoadAccounts(); } }
    private async Task NextPage() { currentPage++; await LoadAccounts(); }

    private async Task CreateAccount()
    {
        if (string.IsNullOrWhiteSpace(newAccount.Name))
        {
            createError = "Account name is required.";
            return;
        }

        isSaving = true;
        createError = null;
        var (success, error, _) = await AccountService.CreateAccountAsync(newAccount);
        if (success)
        {
            showCreateModal = false;
            newAccount = new();
            await LoadAccounts();
        }
        else
        {
            createError = error ?? "Failed to create account.";
        }
        isSaving = false;
    }

    private void CloseModal()
    {
        showCreateModal = false;
        createError = null;
        newAccount = new();
    }
}
