@page "/"
@attribute [Authorize]
@inject IDashboardService DashboardService
@using AIIntegratedCRM.Blazor.Models
@using AIIntegratedCRM.Blazor.Services
@using Microsoft.AspNetCore.Authorization

<PageTitle>Dashboard - AI CRM</PageTitle>

@if (stats is null)
{
    <div class="d-flex justify-content-center align-items-center" style="height:60vh;">
        <div class="text-center">
            <div class="spinner-border text-primary mb-3" style="width:3rem;height:3rem;"></div>
            <p class="text-muted">Loading dashboard...</p>
        </div>
    </div>
}
else
{
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small fw-semibold">TOTAL LEADS</p>
                        <h2 class="mb-0 fw-bold">@stats.TotalLeads</h2>
                        <small class="text-success"><i class="bi bi-arrow-up"></i> @stats.NewLeads new</small>
                    </div>
                    <div class="stat-icon bg-primary-subtle">
                        <i class="bi bi-person-plus text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small fw-semibold">PIPELINE VALUE</p>
                        <h2 class="mb-0 fw-bold">@stats.TotalPipelineValue.ToString("C0")</h2>
                        <small class="text-info">@stats.OpenOpportunities open deals</small>
                    </div>
                    <div class="stat-icon bg-success-subtle">
                        <i class="bi bi-graph-up-arrow text-success"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small fw-semibold">CONTACTS</p>
                        <h2 class="mb-0 fw-bold">@stats.TotalContacts</h2>
                        <small class="text-muted">across @stats.TotalAccounts accounts</small>
                    </div>
                    <div class="stat-icon bg-info-subtle">
                        <i class="bi bi-people text-info"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="stat-card">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted mb-1 small fw-semibold">OPEN TICKETS</p>
                        <h2 class="mb-0 fw-bold">@stats.OpenTickets</h2>
                        <small class="text-muted">@stats.TotalTickets total tickets</small>
                    </div>
                    <div class="stat-icon bg-warning-subtle">
                        <i class="bi bi-headset text-warning"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-xl-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-kanban me-2 text-primary"></i>Sales Pipeline</h6>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-3 overflow-auto pb-2">
                        @foreach (var stage in stats.PipelineByStage)
                        {
                            <div class="pipeline-stage flex-shrink-0">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="fw-semibold small">@stage.Stage</span>
                                    <span class="badge bg-secondary">@stage.Count</span>
                                </div>
                                <div class="fw-bold text-primary">@stage.TotalValue.ToString("C0")</div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="mb-0 fw-semibold"><i class="bi bi-trophy me-2 text-warning"></i>Win Rate</h6>
                </div>
                <div class="card-body d-flex flex-column align-items-center justify-content-center">
                    @{
                        var winRate = stats.TotalOpportunities > 0
                            ? (double)stats.WonOpportunities / stats.TotalOpportunities * 100
                            : 0;
                    }
                    <div class="display-4 fw-bold text-primary">@winRate.ToString("F0")%</div>
                    <p class="text-muted mb-0">@stats.WonOpportunities won of @stats.TotalOpportunities total</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-semibold"><i class="bi bi-clock-history me-2 text-primary"></i>Recent Leads</h6>
            <a href="/leads" class="btn btn-sm btn-outline-primary">View All</a>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Company</th>
                            <th>Status</th>
                            <th>AI Score</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lead in stats.RecentLeads)
                        {
                            <tr>
                                <td class="fw-semibold">@lead.FirstName @lead.LastName</td>
                                <td class="text-muted">@lead.Email</td>
                                <td>@(lead.Company ?? "-")</td>
                                <td><span class="badge @GetStatusBadge(lead.Status) rounded-pill">@lead.Status</span></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="score-bar flex-grow-1" style="width:60px;">
                                            <div class="score-bar-fill" style="width:@lead.AIScore%"></div>
                                        </div>
                                        <small class="fw-semibold">@lead.AIScore</small>
                                    </div>
                                </td>
                                <td class="text-muted small">@lead.CreatedAt.ToString("MMM dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private DashboardStats? stats;

    protected override async Task OnInitializedAsync()
    {
        stats = await DashboardService.GetStatsAsync();
    }

    private static string GetStatusBadge(string status) => status switch
    {
        "New" => "bg-primary",
        "Contacted" => "bg-info",
        "Qualified" => "bg-success",
        "Unqualified" => "bg-danger",
        "Converted" => "bg-secondary",
        _ => "bg-secondary"
    };
}
