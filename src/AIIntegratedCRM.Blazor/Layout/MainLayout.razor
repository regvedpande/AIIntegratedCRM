@inherits LayoutComponentBase
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ILocalStorageService LocalStorage
@using Blazored.LocalStorage
@using AIIntegratedCRM.Blazor.Services

<div class="d-flex">
    @if (isAuthenticated)
    {
        <nav class="sidebar">
            <a class="sidebar-brand" href="/">
                <i class="bi bi-robot fs-4"></i>
                <span>AI CRM</span>
            </a>
            <div class="sidebar-nav">
                <div class="nav-section-title">Main</div>
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </NavLink>
                <div class="nav-section-title">CRM</div>
                <NavLink class="nav-link" href="/leads">
                    <i class="bi bi-person-plus"></i> Leads
                </NavLink>
                <NavLink class="nav-link" href="/contacts">
                    <i class="bi bi-people"></i> Contacts
                </NavLink>
                <NavLink class="nav-link" href="/accounts">
                    <i class="bi bi-building"></i> Accounts
                </NavLink>
                <NavLink class="nav-link" href="/opportunities">
                    <i class="bi bi-graph-up-arrow"></i> Opportunities
                </NavLink>
                <NavLink class="nav-link" href="/activities">
                    <i class="bi bi-calendar-check"></i> Activities
                </NavLink>
                <NavLink class="nav-link" href="/tickets">
                    <i class="bi bi-headset"></i> Support
                </NavLink>
                <div class="nav-section-title">AI Features</div>
                <NavLink class="nav-link" href="/ai-assistant">
                    <i class="bi bi-chat-dots"></i> AI Assistant
                </NavLink>
                <NavLink class="nav-link" href="/email-generator">
                    <i class="bi bi-envelope-plus"></i> Email Generator
                </NavLink>
            </div>
        </nav>
        <div class="main-content flex-grow-1">
            <div class="top-bar">
                <div>
                    <span class="fw-semibold text-dark">@pageTitle</span>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-primary-subtle text-primary rounded-pill">
                        <i class="bi bi-robot me-1"></i>AI Powered
                    </span>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-person-circle me-1"></i>@userName
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><button class="dropdown-item text-danger" @onclick="Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</button></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="page-content">
                @Body
            </div>
        </div>
    }
    else
    {
        @Body
    }
</div>

@code {
    private bool isAuthenticated;
    private string userName = string.Empty;
    private string pageTitle = "Dashboard";

    protected override async Task OnInitializedAsync()
    {
        isAuthenticated = await AuthService.IsAuthenticatedAsync();
        if (isAuthenticated)
            userName = await LocalStorage.GetItemAsStringAsync("user_name") ?? "User";
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
